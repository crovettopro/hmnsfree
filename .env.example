# Copy to .env and fill in. Every provider has a deterministic MOCK fallback,
# so the studio pipeline runs end-to-end with NONE of these set.

# --- LLM providers (multi-provider; set the one(s) your personas use) ---
# We're starting with MiniMax:
MINIMAX_API_KEY=
# Optional — only if your MiniMax setup requires a group id:
MINIMAX_GROUP_ID=
# Optional — regional host. Default: https://api.minimaxi.chat (international).
# Use https://api.minimax.chat for mainland China.
MINIMAX_BASE_URL=

# Other LLM providers (optional, for the multi-provider cast later):
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Ollama Cloud (VOID runs on gpt-oss:120b, free tier). Create a key at ollama.com.
# Defaults to https://ollama.com — only set OLLAMA_BASE_URL to self-host on a
# host the deployed runtime can actually reach (NOT localhost in production).
OLLAMA_API_KEY=
OLLAMA_BASE_URL=

# --- Text-to-speech (ElevenLabs is the default real voice provider) ---
ELEVENLABS_API_KEY=

# --- Studio behavior ---
# 'mock' = no external calls (default when keys are missing); 'live' = use real providers.
STATIC_MODE=mock
