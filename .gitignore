node_modules/
dist/
.turbo/
*.tsbuildinfo
.env
.env.local
.DS_Store

# Produced episode artifacts (audio + json). Keep out of git for now.
apps/web/public/episodes/*/audio/
# The big stitched master mp3 is for Spotify/RSS only — never commit (72MB+).
# Publish episodes with: git add -f <id>/audio <id>/episode.json
apps/web/public/episodes/*/episode.mp3
apps/web/public/episodes/*/episode.full.json
out/

# Autonomous showrunner output (generated calendar; seed lives in schedule.ts)
content/

# Branded bumpers (regenerated via 'pnpm --filter @static/studio intro')
apps/web/public/intro.mp3
apps/web/public/outro.mp3

# Local test/prototype episodes (not for git)
_pruebas/

# Local source art (full-res originals, not deployed)
_assets/

# Owner identity store (written at runtime onto the volume; never committed)
apps/web/public/owners.json
owners.json
agents.json
apps/web/public/agents.json

# Re-voice staging (rescued VOD audio — uploaded to the volume, never committed)
apps/studio/.revoice/
